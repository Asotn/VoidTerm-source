<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VoidTerm"
        android:textColor="#00FF77"
        android:textSize="28sp"
        android:fontFamily="monospace"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingTop="32dp"
        android:paddingBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Kali Linux Terminal for Android"
        android:textColor="#AAAAAA"
        android:textSize="14sp"
        android:fontFamily="monospace"
        android:gravity="center"
        android:paddingBottom="32dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Version: 26.2\nLicense: GPL-3.0\nF-Droid: Ready\n\nDeveloper: Asotn\nGitHub: github.com/Asotn\nEmail: s.pi@outlook.sa"
        android:textColor="#CCCCCC"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:lineSpacingMultiplier="1.5"
        android:gravity="center"
        android:paddingBottom="40dp" />

    <Button
        android:id="@+id/btn_github"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Open GitHub"
        android:fontFamily="monospace"
        android:layout_marginBottom="12dp"
        style="@style/Widget.AppCompat.Button.Borderless" />

    <Button
        android:id="@+id/btn_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Send Email"
        android:fontFamily="monospace"
        style="@style/Widget.AppCompat.Button.Borderless" />

</LinearLayout>
